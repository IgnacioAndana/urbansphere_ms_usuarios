PORT=3001

DB_HOST=localhost
DB_PORT=3306
DB_NAME=porsusde_urbansphere
DB_USER=tu_usuario
DB_PASSWORD=tu_password

JWT_SECRET=urbansphere-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Correo — Mailtrap (https://mailtrap.io → Email Sending → API Tokens)
MAILTRAP_API_TOKEN=tu_api_token
MAIL_FROM=contacto@urbansphere.cl
MAIL_FROM_NAME=UrbanSphere

# Recuperación de contraseña
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_PATH=/restablecer-contrasena
PASSWORD_RESET_EXPIRES_IN=1h

HTTP_LOGGING=true
NODE_ENV=development
DB_SYNCHRONIZE=false
DB_LOGGING=false
